ENVIRONMENT=production

# Managed services
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
REDIS_URL=rediss://:PASSWORD@HOST:PORT

# Runtime behavior
CARD_CACHE_BACKEND=postgres
SCRYFALL_BULK_PATH=/tmp/scryfall-oracle-cards.json
RULES_CACHE_DIR=/tmp/rules

# Frontend/API integration
APP_BASE_URL=https://your-netlify-domain
CORS_ALLOWED_ORIGINS=https://your-netlify-domain
TRUSTED_HOSTS=api.your-api-domain
FORCE_HTTPS=1

# Optional
SENTRY_DSN=
