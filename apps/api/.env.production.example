ENVIRONMENT=production

# Managed services
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
REDIS_URL=rediss://:PASSWORD@HOST:PORT

# Runtime behavior
CARD_CACHE_BACKEND=postgres
SCRYFALL_BULK_PATH=/tmp/scryfall-oracle-cards.json
RULES_CACHE_DIR=/tmp/rules

# Frontend/API integration
APP_BASE_URL=https://your-netlify-domain
CORS_ALLOWED_ORIGINS=https://your-netlify-domain
TRUSTED_HOSTS=api.your-api-domain
FORCE_HTTPS=1

# Optional
SENTRY_DSN=
AI_ENABLED=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
AI_TIMEOUT_S=6
AI_MAX_OUTPUT_TOKENS=1200
AI_CACHE_TTL_S=86400
AI_HIDE_UNVERIFIABLE=1
AI_DAILY_BUDGET_USD=2.0

# Auth / saved decks
AUTH_SESSION_TTL_DAYS=30
AUTH_COOKIE_NAME=dc_session
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_SAMESITE=none
AUTH_CSRF_HEADER=X-CSRF-Token
AUTH_CSRF_STORAGE_KEY=deckcheck.csrf
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_S=900
AUTH_MAGIC_LINK_TTL_MINUTES=30
AUTH_EMAIL_FROM=Deck.Check <noreply@deck.check>
RESEND_API_KEY=
ADMIN_EMAILS=florian.sonderegger@me.com
